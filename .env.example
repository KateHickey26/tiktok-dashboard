TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Must match the redirect URI in your TikTok app settings exactly
REDIRECT_URI=https://tiktok-dashboard-two.vercel.app/api/auth/callback

# Upstash Redis — get these from console.upstash.com after creating a Redis database
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
